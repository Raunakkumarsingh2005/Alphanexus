# AlphaNexus Environment Variables
# Copy to .env and fill in your values

# ── Database ──────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/alphanexus

# ── Auth (JWT) ────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── PocketBase (optional — leave blank if not using) ──────────
# POCKETBASE_URL=http://localhost:8090

# ── External API Keys ─────────────────────────────────────────
FINNHUB_API_KEY=YOUR_FINNHUB_KEY
NEWSAPI_KEY=YOUR_NEWSAPI_KEY
QUIVER_API_KEY=YOUR_QUIVER_KEY_OR_LEAVE_BLANK

# ── App ───────────────────────────────────────────────────────
DEBUG=True
